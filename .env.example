# Stock.Tool Environment Variables
# Copy this file to .env and fill in your credentials

# ===========================================
# Interactive Brokers TWS Socket API
# ===========================================
# Enable IBKR as the primary data source (set to "true" to enable)
IBKR_ENABLED=false

# TWS Socket connection (IB Gateway)
# Port: 4001 for live IB Gateway, 4002 for paper trading
IBKR_TWS_PORT=4001
IBKR_TWS_HOST=127.0.0.1
IBKR_CLIENT_ID=0

# ===========================================
# Alpha Vantage API (Fallback)
# ===========================================
# Get your free API key at: https://www.alphavantage.co/support/#api-key
STOCK_API_KEY=demo

# ===========================================
# Finnhub API (News)
# ===========================================
# Get your free API key at: https://finnhub.io/
FINNHUB_API_KEY=

# ===========================================
# Anthropic API (Portfolio Image Scanning)
# ===========================================
# Get your API key at: https://console.anthropic.com/
# Used for scanning portfolio screenshots with Claude Vision
ANTHROPIC_API_KEY=

# ===========================================
# IB Gateway Setup Instructions
# ===========================================
# 1. Download IB Gateway from:
#    https://www.interactivebrokers.com/en/trading/ibgateway-stable.php
#
# 2. Run IB Gateway, select "IB API" mode, log in
#
# 3. Note the Local Port in gateway settings (default 4001 live, 4002 paper)
#
# 4. Set IBKR_TWS_PORT to match, set IBKR_ENABLED=true
#
# 5. npm install @stoqey/ib   (TWS socket API library)
#
# Note: The gateway session expires periodically. You may need to re-authenticate
# via the gateway's web interface if you get authentication errors.
