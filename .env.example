# Stock.Tool Environment Variables
# Copy this file to .env and fill in your credentials

# ===========================================
# Interactive Brokers Client Portal API
# ===========================================
# The URL where your IB Gateway or Client Portal Gateway is running
# Default: https://localhost:5000
IBKR_GATEWAY_URL=https://localhost:5000

# Your Interactive Brokers Account ID (optional - will auto-detect if not set)
IBKR_ACCOUNT_ID=

# Enable IBKR as the primary data source (set to "true" to enable)
# When enabled, real-time data will be fetched from IB instead of Alpha Vantage
IBKR_ENABLED=false

# ===========================================
# Alpha Vantage API (Fallback)
# ===========================================
# Get your free API key at: https://www.alphavantage.co/support/#api-key
STOCK_API_KEY=demo

# ===========================================
# Finnhub API (News)
# ===========================================
# Get your free API key at: https://finnhub.io/
FINNHUB_API_KEY=

# ===========================================
# IB Gateway Setup Instructions
# ===========================================
# 1. Download IB Gateway from:
#    https://www.interactivebrokers.com/en/trading/ibgateway-stable.php
#
# 2. Or use Client Portal Gateway:
#    https://www.interactivebrokers.com/en/index.php?f=50598
#
# 3. Run the gateway - it will start on https://localhost:5000 by default
#
# 4. Open https://localhost:5000 in your browser and log in with your IB credentials
#
# 5. Once authenticated, the Stock.Tool app can fetch real-time data
#
# Note: The gateway session expires periodically. You may need to re-authenticate
# via the gateway's web interface if you get authentication errors.
